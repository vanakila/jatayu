generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model Post {
  id         String   @id @default(cuid())
  type       String   // "BERITA" | "ARTIKEL"
  title      String
  slug       String   @unique
  excerpt    String?
  content    String
  coverImage String?
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  createdAt DateTime @default(now())
}

model Profile {
  id        String   @id @default(cuid())
  content   String
  updatedAt DateTime @updatedAt
}

model VisiMisi {
  id        String   @id @default(cuid())
  content   String
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  createdAt DateTime @default(now())
}
